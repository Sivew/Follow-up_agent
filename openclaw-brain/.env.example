# Model Providers
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key
GOOGLE_API_KEY=your_google_key

# Default Model
DEFAULT_MODEL=anthropic/claude-sonnet-4

# Database
DATABASE_PATH=./data/brain.db

# API Settings
PORT=3000
LOG_LEVEL=info

# Feature Flags
ENABLE_MEMORY=true
ENABLE_LEARNING=true
